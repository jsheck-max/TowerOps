# TowerOps Environment Configuration
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://towerops:towerops@localhost:5432/towerops

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# Frontend
VITE_API_URL=http://localhost:8000/api/v1

# Integrations (add as needed)
# WORKYARD_API_KEY=
# WORKYARD_API_URL=https://api.workyard.com/v1
